# Server-only env. Never prefixed with NEXT_PUBLIC_ — must not reach the browser bundle.
# Local dev: backend uvicorn on :8000.
# Production: set on Vercel dashboard to your VM's URL (e.g. http://<vm-ip>:8000).
BACKEND_URL=http://localhost:8000

# Public OAuth bootstrap URL. Used by the "Sign in" link on `/` to hand off to
# the backend's /auth/login endpoint (top-level navigation, not API call).
# This is intentionally NEXT_PUBLIC_ — the URL has to be available in the browser.
# Local dev: http://localhost:8000
# Production: https://knock-api.koreacentral.cloudapp.azure.com
NEXT_PUBLIC_BACKEND_OAUTH_URL=http://localhost:8000
